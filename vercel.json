{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "outputDirectory": "public",
    "functions": {
        "api/lambda.php": {
            "runtime": "vercel-php@0.8.0"
        }
    },

    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        }
    ],

    "rewrites": [{ "source": "/(.*)", "destination": "/api/lambda.php" }]
}
